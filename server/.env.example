PORT=5000
MONGO_URI=mongodb://localhost:27017/resume-builder
GEMINI_API_KEY=your_gemini_api_key_here
CLIENT_URL=http://localhost:5173

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_string_access
JWT_REFRESH_SECRET=replace_with_a_long_random_string_refresh

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Authorised JS origins: http://localhost:5173
# Authorised redirect URIs: not required for One-Tap / popup flow
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
